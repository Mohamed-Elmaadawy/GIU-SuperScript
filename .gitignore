# Ignore everything
*

# Shipped userscripts (bundle + theme in scripts/, standalones in scripts/individual/)
!scripts/
!scripts/*.js
!scripts/individual/
!scripts/individual/*.js

# Local-only dev / scraper / screenshot tooling — never tracked
scripts/dev/

# Aggregator standalone kept untracked
scripts/individual/GIU Proctor Schedule Aggregator.js

# Tests
!tests/
!tests/**

# Aggregator test files (kept untracked)
tests/proctor-aggregator.spec.js
tests/fixtures/dept-response.html
tests/fixtures/exchange-page.html
tests/fixtures/proctor-response.html

# README screenshots
!screenshots/
!screenshots/*

# Root files
!README.md
!.gitignore
.env

# Docs
docs/
