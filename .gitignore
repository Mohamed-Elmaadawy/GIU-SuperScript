# Ignore everything
*

# Shipped userscripts (bundle + theme in scripts/, standalones in scripts/individual/)
!scripts/
!scripts/*.js
!scripts/individual/
!scripts/individual/*.js

# Local-only dev / scraper / screenshot tooling — never tracked
scripts/dev/

# Aggregator standalone kept untracked
scripts/individual/GIU Proctor Schedule Aggregator.js

# Tests — local-only, not tracked (covered by the global * ignore)

# README screenshots
!screenshots/
!screenshots/*

# Root files
!README.md
!.gitignore
.env

# Docs
docs/
